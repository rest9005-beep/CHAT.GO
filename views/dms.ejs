<div class="card" style="margin-top:16px">
  <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap">
    <div>
      <div class="h1">Личные чаты</div>
      <p class="p">Все твои переписки. Нажми на чат, чтобы открыть.</p>
    </div>
    <a class="btn" href="/search">Найти человека</a>
  </div>

  <div class="hr"></div>

  <% if (!threads.length) { %>
    <div class="small">Пока нет переписок. Открой <a href="/search">поиск</a> и напиши кому-нибудь.</div>
  <% } else { %>
    <div class="searchResults">
      <% threads.forEach(t => { %>
        <a class="userItem" href="/dm/<%= encodeURIComponent(t.peer.username) %>">
          <div class="ava"><img src="<%= t.peer.avatar_path || '/default-avatar.svg' %>" alt="ava"></div>
          <div style="min-width:0">
            <div class="u"><%= t.peer.username %></div>
            <div class="d" style="max-width:520px">
              <% if (t.last) { %>
                <%= (t.last.text && t.last.text.length) ? t.last.text : (t.last.attachment ? '[вложение]' : '') %>
              <% } else { %>
                Нет сообщений
              <% } %>
            </div>
          </div>
          <span class="pill"><%= t.last ? new Date(t.last.created_at).toLocaleString(undefined,{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '' %></span>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
